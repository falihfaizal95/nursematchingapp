# Supabase project settings — from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used by admin invite actions (src/lib/actions/admin-people.ts). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Used to build invite/reset email redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
