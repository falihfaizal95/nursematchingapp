# Supabase project settings — from https://supabase.com/dashboard/project/_/settings/api
# EXPO_PUBLIC_ vars are bundled into the app and are safe to ship on-device
# (RLS is what protects data, not secrecy of these).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The service role key is NOT needed here. It's used only by the repo
# root's scripts/seed.ts and is provided automatically to the invite-user
# Edge Function by the Supabase platform — it never ships in this app.
