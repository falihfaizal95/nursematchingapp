# Supabase project settings — from https://supabase.com/dashboard/project/_/settings/api
# EXPO_PUBLIC_ vars are bundled into the app and are safe to ship on-device.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER prefix this with EXPO_PUBLIC_. Used only by
# scripts/seed.ts (a local Node script) and as a Supabase Edge Function
# secret (`supabase secrets set`) for the invite-user function. Never
# ships inside the app bundle.
SUPABASE_SERVICE_ROLE_KEY=
